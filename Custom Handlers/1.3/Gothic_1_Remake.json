{
  "name": "Gothic 1 Remake",
  "game_id": "Gothic_1_Remake",
  "exe_name": "G1R/Binaries/Win64/G1R-Win64-Shipping.exe",
  "deploy_type": "ue5",
  "mod_data_path": "G1R",
  "steam_id": "1297900",
  "nexus_game_domain": "gothic1remake",
  "image_url": "https://cdn2.steamgriddb.com/icon/fccae97cf98da619b1b7ab8d85fde5e3/32/512x512.png",
  "mod_folder_strip_prefixes": [
    "g1r",
    "binaries",
    "win64",
    "content",
    "paks",
    "~mods",
    "Mods"
  ],
  "conflict_ignore_filenames": [
    "*.md",
    "*read*.txt",
    "*.appimage",
    "*.deb"
  ],
  "mod_folder_strip_prefixes_post": [],
  "mod_install_prefix": "",
  "mod_required_top_level_folders": [],
  "mod_auto_strip_until_required": true,
  "mod_required_file_types": [],
  "mod_install_as_is_if_no_match": true,
  "restore_before_deploy": true,
  "normalize_folder_case": true,
  "filemap_casing": "upper",
  "wine_dll_overrides": {
    "dwmapi": "native,builtin",
    "dsound": "native,builtin"
  },
  "custom_routing_rules": [
    {
      "dest": "drive_c/users/steamuser/AppData/Local/G1R/Saved/Config/Windows",
      "filenames": [
        "engine.ini",
        "scalability.ini",
        "GameUserSettings.ini"
      ],
      "flatten": true,
      "to_prefix": true
    },
    {
      "dest": "drive_c/users/steamuser/AppData/Local/G1R/Saved/SaveGames",
      "extensions": [
        ".sav"
      ],
      "flatten": true,
      "to_prefix": true
    },
    {
      "dest": "Binaries/Win64",
      "folders": [
        "reshade-shaders"
      ],
      "include_siblings": true
    },
    {
      "dest": "Binaries/Win64",
      "extensions": [
        ".addon64"
      ]
    },
    {
      "dest": "",
      "folders": [
        "Story"
      ],
      "flatten": true
    },
    {
      "dest": "Mods",
      "extensions": [
        ".uplugin"
      ],
      "include_siblings": true
    },
    {
      "dest": "Content/Paks/~mods",
      "extensions": [
        ".pak"
      ],
      "companion_extensions": [
        ".ucas",
        ".utoc"
      ],
      "flatten": true
    },
    {
      "dest": "Binaries/Win64",
      "filenames": [
        "*reshade*.*"
      ]
    },
    {
      "dest": "Binaries/Win64",
      "folders": [
        "ue4ss"
      ],
      "flatten": true
    },
    {
      "dest": "Binaries/Win64/ue4ss/Mods",
      "folders": [
        "scripts"
      ],
      "include_siblings": true
    },
    {
      "dest": "Binaries/Win64/ue4ss/Mods",
      "filenames": [
        "enabled.txt"
      ],
      "include_siblings": true
    },
    {
      "dest": "Binaries/Win64/ue4ss/Mods",
      "filenames": [
        "mods.txt"
      ]
    },
    {
      "dest": "Content/Splash",
      "extensions": [
        ".bmp"
      ],
      "flatten": true
    },
    {
      "dest": "ManualInstall",
      "extensions": [
        ".ogg",
        ".png",
        ".ct"
      ],
      "include_siblings": true
    }
  ],
  "custom_frameworks": {
    "UE4SS": "Binaries/Win64/dwmapi.dll"
  },
  "version": 2,
  "editable": false
}
