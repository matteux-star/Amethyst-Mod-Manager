{
  "name": "The Last Caretaker",
  "game_id": "The_Last_Caretaker",
  "exe_name": "Voyage/Binaries/Win64/VoyageSteam-Win64-Shipping.exe",
  "deploy_type": "ue5",
  "mod_data_path": "Voyage",
  "steam_id": "1783560",
  "nexus_game_domain": "thelastcaretaker",
  "image_url": "https://cdn2.steamgriddb.com/thumb/d5d34729089c31b82d05dda62e20ee0c.jpg",
  "mod_folder_strip_prefixes": [
    "Binaries",
    "Win64",
    "Content",
    "Paks",
    "~mods",
    "Mods"
  ],
  "conflict_ignore_filenames": [
    "*read*.txt"
  ],
  "mod_folder_strip_prefixes_post": [],
  "mod_install_prefix": "",
  "mod_required_top_level_folders": [],
  "mod_auto_strip_until_required": false,
  "mod_required_file_types": [],
  "mod_install_as_is_if_no_match": false,
  "restore_before_deploy": true,
  "normalize_folder_case": true,
  "filemap_casing": "upper",
  "wine_dll_overrides": {
    "dwmapi": "native,builtin",
    "winhttp": "native,builtin"
  },
  "custom_routing_rules": [
    {
      "dest": "drive_c/users/steamuser/AppData/LocalVoyage/Saved/Config/Windows",
      "filenames": [
        "Engine.ini"
      ],
      "flatten": true,
      "to_prefix": true
    },
    {
      "dest": "drive_c/users/steamuser/AppData/LocalVoyage/Saved/Config/Windows",
      "filenames": [
        "Scalability.ini"
      ],
      "flatten": true,
      "to_prefix": true
    },
    {
      "dest": "Binaries/Win64",
      "folders": [
        "ue4ss"
      ],
      "flatten": true
    },
    {
      "dest": "Content/Paks",
      "folders": [
        "dml"
      ]
    },
    {
      "dest": "Content/Paks",
      "extensions": [
        ".pak"
      ],
      "include_siblings": true
    },
    {
      "dest": "Content/Paks",
      "extensions": [
        ".ucas"
      ],
      "include_siblings": true
    },
    {
      "dest": "Content/Paks",
      "extensions": [
        ".utoc"
      ],
      "include_siblings": true
    },
    {
      "dest": "Content",
      "folders": [
        "Movies"
      ],
      "flatten": true
    },
    {
      "dest": "Binaries/Win64",
      "extensions": [
        ".asi"
      ],
      "companion_extensions": [
        ".pdb",
        ".ini"
      ]
    },
    {
      "dest": "Binaries/Win64/ue4ss/Mods",
      "filenames": [
        "main.lua"
      ],
      "include_siblings": true
    },
    {
      "dest": "Binaries/Win64/ue4ss/Mods",
      "filenames": [
        "mods.txt"
      ],
      "flatten": true
    }
  ],
  "custom_frameworks": {
    "ue4ss": "Binaries/Win64/ue4ss/UE4SS.dll"
  },
  "version": 2,
  "editable": false
}
