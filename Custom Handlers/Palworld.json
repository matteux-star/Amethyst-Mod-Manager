        "Main.lua"
      ],
      "include_siblings": true
    },
    {
      "dest": "Binaries/Win64/Mods",
      "filenames": [
        "enabled.txt"
      ],
      "include_siblings": true
    },
    {
      "dest": "Binaries/Win64/Mods",
      "folders": [
        "Scripts"
      ],
      "include_siblings": true
    },
    {
      "dest": "Binaries/Win64/Mods",
      "folders": [
        "Shared"
      ],
      "flatten": true
    }
  ],
  "custom_frameworks": {},
  "version": 4,
